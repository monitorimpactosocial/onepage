FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=change-this-secret
DATABASE_URL=sqlite:///instance/paracel_onepage.db
WORKBOOK_TEMPLATE=data/PARACEL_repositorio_mensual_template.xlsx
WORKBOOK_OUTPUT=instance/PARACEL_repositorio_mensual_online.xlsx
REMINDER_DAY=25
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change-me
SMTP_USE_TLS=true
MAIL_FROM=reportes@paracel.com.py
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_DRIVE_ID=
GRAPH_UPLOAD_PATH=/Paracel/Reportes/PARACEL_repositorio_mensual_online.xlsx

UPLOAD_FOLDER=instance/uploads
MAX_CONTENT_LENGTH=26214400
